# VisualVault Environment Configuration
# Copy this file to .env and update values for your environment

# ===================
# Application Settings
# ===================
DEBUG=true
ENVIRONMENT=development  # development, staging, production

# ===================
# Database Settings
# ===================
DB_HOST=localhost
DB_PORT=5432
DB_USER=visualvault
DB_PASSWORD=visualvault
DB_NAME=visualvault

# ===================
# Redis Settings
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # Uncomment if Redis requires auth

# ===================
# Storage Settings
# ===================
STORAGE_BASE_PATH=storage
STORAGE_MAX_FILE_SIZE_MB=10

# ===================
# Authentication Settings
# ===================
# IMPORTANT: Generate a secure key for production!
# Run: openssl rand -hex 32
AUTH_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_RATE_LIMIT_PER_MINUTE=60

# ===================
# ML Settings
# ===================
ML_DEVICE=cpu  # cpu, cuda, or mps (Apple Silicon)
ML_MODELS_DIR=models

# ===================
# Celery Settings
# ===================
CELERY_TASK_ALWAYS_EAGER=false  # Set true for testing without Redis
CELERY_WORKER_CONCURRENCY=2

# ===================
# CORS Settings
# ===================
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
